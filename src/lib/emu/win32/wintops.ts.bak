export function registerOpenBrowser(emu: Emulator): void {
  const web = emu.registerDll('WEB.DLL');

  web.register('OpenBrowser', 3, () => {
    try {
    
   
      const url   = emu.memory.readCString(emu.readArg(0));   // 第二个参数
      const title = emu.memory.readCString(emu.readArg(1)); // 第三个参数
      const name = emu.memory.readCString(emu.readArg(2)); // 第三个参数

    //  console.log('[web.dll] OpenBrowser:', url, title,name);
url='/';
      (window as any).openBrowser?.(url, title,name);
      return 1;
    } catch (e) {
      console.error('OpenBrowser failed:', e);
      return 0;
    }
  });
  
        web.register('log', 1, () =>  {
 
    console.log('  [LOG]: '+ emu.memory.readCString(emu.readArg(0)));
    return 0;
  });
  
}

 
