 // ==========================
// RtlCompareUnicodeString
// ==========================
ntdll.register('RtlCompareUnicodeString', 3, () => {
  // 参数：String1, String2, CaseInSensitive
  const str1Ptr = emu.readArg(0);
  const str2Ptr = emu.readArg(1);
  const caseInsensitive = emu.readArg(2) !== 0;

  // 读取 UNICODE_STRING 结构
  const len1 = emu.memory.readU16(str1Ptr);       // 字节长度
  const buf1 = emu.memory.readU32(str1Ptr + 4);   // 字符串指针

  const len2 = emu.memory.readU16(str2Ptr);
  const buf2 = emu.memory.readU32(str2Ptr + 4);

  // 转成字符数
  const charCount1 = len1 / 2;
  const charCount2 = len2 / 2;
  const minLen = Math.min(charCount1, charCount2);

  let res = 0;

  for (let i = 0; i < minLen; i++) {
    let c1 = emu.memory.readU16(buf1 + i * 2);
    let c2 = emu.memory.readU16(buf2 + i * 2);

    // 忽略大小写：A-Z 与 a-z 视为相同
    if (caseInsensitive) {
      if (c1 >= 0x61 && c1 <= 0x7A) c1 -= 0x20;
      if (c2 >= 0x61 && c2 <= 0x7A) c2 -= 0x20;
    }

    if (c1 !== c2) {
      res = c1 - c2;
      break;
    }
  }

  // 前面都相同 → 比较长度
  if (res === 0) {
    res = charCount1 - charCount2;
  }

  // 返回：-1 / 0 / 1
  if (res < 0) return -1;
  if (res > 0) return 1;
  return 0;
});



 
 
shell32.register('ShellExecute', 6, () => {
  try {
    const hwnd = emu.readArg(0);
    const op   = emu.memory.readCString(emu.readArg(1));
    const file = emu.memory.readCString(emu.readArg(2)); // ← URL/程序路径
    const params = emu.readArg(3);
    const dir    = emu.readArg(4);
    const show   = emu.readArg(5);

 

    // 打开网页
    if (file.startsWith("http")) {
      window.open(file, '_blank');
    }

    return 33; // ≥32 表示成功
  } catch {
    return 0;
  }
});

 


  
