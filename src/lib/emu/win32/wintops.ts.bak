  registerWinHttp(emu);
  registerOpenBrowser(emu);
  
  const kernel32 = emu.registerDll('KERNEL32.DLL');
  const user32 = emu.registerDll('USER32.DLL');
    const gdi32 = emu.registerDll('GDI32.DLL');
    const opengl32 = emu.registerDll('OPENGL32.DLL');
    const ntdll = emu.registerDll('NTDLL.DLL');
      const shell32 = emu.registerDll('SHELL32.DLL');
    
       const wtsapi = emu.registerDll('WTSAPI32.DLL');
    wtsapi.register('wtsapi', 1, () => 0); // S_OK
    
          function unRegisterAPI(dllName:string,name: string ): void {
    const key = `${dllName}:${name}`;
    if (emu.apiDefs.has(key)) {
    emu.apiDefs.delete(key);
     
    }
 
  }


  unRegisterAPI('USER32.DLL','MoveWindow');
  unRegisterAPI('USER32.DLL','ShowWindow');
  unRegisterAPI('GDI32.DLL','Rectangle');
  unRegisterAPI('GDI32.DLL','StretchDIBits');
   //unRegisterAPI('GDI32.DLL','TextOutA');
   
     user32.register('CharToOemW', 2, () => 1);

    user32.register('GetComboBoxInfo', 2, () => 1);
    
   const getFontCSS = (hdc: number): string => {
    const sz = getFontSize(hdc);
    const dc = emu.getDC(hdc);
    const font = dc ? emu.handles.get<{ height: number; faceName?: string }>(dc.selectedFont) : null;
    const face = font?.faceName || 'Tahoma';
    return `${sz}px "${face}", Tahoma, sans-serif`;
  };
  
  
  
    const getFontSize = (hdc: number): number => {
    const dc = emu.getDC(hdc);
    if (!dc) return 13;
    const font = emu.handles.get<{ height: number }>(dc.selectedFont);
    if (font && font.height) {
      const h = Math.abs(font.height);
      // Negative lfHeight = character height (excludes internal leading).
      // Estimate cell height (tmHeight) by adding ~20% for internal leading.
      if (font.height < 0) return Math.round(h * 1.2);
      return h; // positive lfHeight = cell height directly
    }
    return 13;
  };
  
    gdi32.register('TextOutA2', 5, () => {
    const hdc = emu.readArg(0);
    const x = emu.readArg(1) | 0;
    const y = emu.readArg(2) | 0;
    const strPtr = emu.readArg(3);
    const count = emu.readArg(4);

    const dc = emu.getDC(hdc);
    if (!dc) return 0;

    const text = emu.memory.readBytesMBCS(strPtr, count);
  console.log(`[TextOutA]  ${text} ${x} ${y} `);
    const fontSize = getFontSize(hdc);
    dc.ctx.font = getFontCSS(hdc);
    if (dc.bkMode === OPAQUE) {
      dc.ctx.fillStyle = colorToCSS(dc.bkColor);
      const m = dc.ctx.measureText(text);
      dc.ctx.fillRect(x, y, m.width, fontSize);
    }
    dc.ctx.fillStyle = colorToCSS(dc.textColor);
    dc.ctx.textBaseline = 'top';
    fillTextBitmap(dc.ctx, text, x, y);

    emu.syncDCToCanvas(hdc);
    return 1;
  });
 
