import type { Emulator, WinHttpSession, WinHttpConnect, WinHttpRequest, WinHttpHandleData } from '../emulator';

// ==========================
// WinHTTP 常量定义
// ==========================
const WINHTTP_NO_PROXY_NAME = 0;
const WINHTTP_NO_PROXY_BYPASS = 0;
const WINHTTP_FLAG_ASYNC = 0x00000001;
const WINHTTP_FLAG_SECURE = 0x00800000;
const WINHTTP_FLAG_REFRESH = 0x10000000;

const WINHTTP_ACCESS_TYPE_DEFAULT_PROXY = 0;
const WINHTTP_ACCESS_TYPE_NO_PROXY = 1;
const WINHTTP_ACCESS_TYPE_NAMED_PROXY = 3;

const WINHTTP_RESOLVE_TIMEOUT = 0;
const WINHTTP_CONNECT_TIMEOUT = 60000;
const WINHTTP_SEND_TIMEOUT = 30000;
const WINHTTP_RECEIVE_TIMEOUT = 30000;
const WINHTTP_RECEIVE_RESPONSE_TIMEOUT = 30000;

const WINHTTP_OPTION_PROXY = 2;
const WINHTTP_OPTION_CONNECT_TIMEOUT = 3;
const WINHTTP_OPTION_RECEIVE_TIMEOUT = 6;
const WINHTTP_OPTION_SEND_TIMEOUT = 5;
const WINHTTP_OPTION_RESOLVE_TIMEOUT = 2;

const ERROR_WINHTTP_INCORRECT_HANDLE_TYPE = 12173;
const ERROR_WINHTTP_INTERNAL_ERROR = 12174;
const ERROR_WINHTTP_INVALID_URL = 12180;
const ERROR_WINHTTP_UNRECOGNIZED_SCHEME = 12181;
const ERROR_WINHTTP_NAME_NOT_RESOLVED = 12182;
const ERROR_WINHTTP_INVALID_OPTION_ID = 12185;
const ERROR_WINHTTP_OPTION_NOT_SETTABLE = 12186;
const ERROR_WINHTTP_SHUTDOWN = 12191;
const ERROR_WINHTTP_LOGIN_FAILURE = 12193;
const ERROR_WINHTTP_OPERATION_CANCELLED = 12197;
const ERROR_WINHTTP_INCORRECT_HANDLE_STATE = 12198;
const ERROR_WINHTTP_NOT_INITIALIZED = 12172;
const ERROR_WINHTTP_TIMEOUT = 12002;
const ERROR_WINHTTP_SECURE_FAILURE = 12175;
const ERROR_WINHTTP_AUTO_PROXY_SERVICE_ERROR = 12178;
const ERROR_WINHTTP_BAD_AUTO_PROXY_SCRIPT = 12179;
const ERROR_WINHTTP_UNABLE_TO_DOWNLOAD_SCRIPT = 12183;
const ERROR_WINHTTP_SECURE_INVALID_CERT = 12169;
const ERROR_WINHTTP_SECURE_CERT_REV_FAILED = 12170;
const ERROR_WINHTTP_SECURE_CERT_REQUIRES_REV = 12171;
const ERROR_WINHTTP_SECURE_CERT_DATE_INVALID = 12137;
const ERROR_WINHTTP_SECURE_CERT_SUBJECT_INVALID = 12138;
const ERROR_WINHTTP_SECURE_CERT_WRONG_USAGE = 12149;
const ERROR_WINHTTP_SECURE_INVALID_CERT_CHAIN = 12193;
const ERROR_WINHTTP_SECURE_SERVER_CERT_STATE_INVALID = 12163;

const INTERNET_SCHEME_HTTP = 1;
const INTERNET_SCHEME_HTTPS = 2;
const INTERNET_SCHEME_FTP = 3;

const HTTP_QUERY_HOST = 26;
const HTTP_QUERY_CONTENT_TYPE = 1;
const HTTP_QUERY_CONTENT_LENGTH = 5;
const HTTP_QUERY_STATUS_CODE = 19;
const HTTP_QUERY_RAW_HEADERS_CRLF = 21;
const HTTP_QUERY_FLAG_REQUEST_HEADERS = 0x80000000;

const HTTP_STATUS_OK = 200;
const HTTP_STATUS_BAD_REQUEST = 400;
const HTTP_STATUS_NOT_FOUND = 404;
const HTTP_STATUS_SERVER_ERROR = 500;

let nextHandle = 0x10000;

// ==========================
// 辅助工具：宽字符 (UTF-16) 写入
// ==========================
function writeUTF16String(emu: Emulator, ptr: number, str: string): number {
  for (let i = 0; i < str.length; i++) {
    emu.memory.writeU16(ptr + i * 2, str.charCodeAt(i));
  }
  emu.memory.writeU16(ptr + str.length * 2, 0); // Null 终止符
  return (str.length + 1) * 2; // 返回消耗的字节数
}

// ==========================
// 自动请求：完美支持同步二进制
// ==========================
function fetchAutoResponse(url: string): {
  isBinary: boolean;
  body: Uint8Array;
  contentType: string;
  statusCode: number;
} | null {
  try {
    const xhr = new XMLHttpRequest();
    xhr.open('GET', url, false); // 同步请求

    // 🌟 核心黑科技：防止浏览器将二进制数据当作 UTF-8 解析而导致损坏
    // 这是在 XMLHttpRequest 同步模式下获取二进制流的唯一安全方案
    xhr.overrideMimeType('text/plain; charset=x-user-defined');
    xhr.send(null);

    const text = xhr.responseText;
    // 将 user-defined 字符映射回真实的二进制字节
    const body = new Uint8Array(text.length);
    for (let i = 0; i < text.length; i++) {
      body[i] = text.charCodeAt(i) & 0xFF;
    }

    const contentType = xhr.getResponseHeader('Content-Type') || 'application/octet-stream';
    const isJson = contentType.includes('application/json');

    return {
      isBinary: !contentType.includes('text/') && !isJson,
      body,
      contentType,
      statusCode: xhr.status
    };
  } catch (err) {
    console.error('[WinHTTP] fetch failed:', err);
    return null;
  }
}

export function registerWinHttp(emu: Emulator): void {
  const winhttp = emu.registerDll('WINHTTP.DLL');
  emu.winHttpHandles = new Map();

  function hAlloc(type: string, data: any) {
    const h = nextHandle++;
    emu.winHttpHandles.set(h, { type, data });
    return h;
  }

  // ------------------------------
  // 基础 API & 句柄关联
  // ------------------------------
  winhttp.register('WinHttpOpen', 5, () => hAlloc('session', {}));

  winhttp.register('WinHttpCloseHandle', 1, () => {
    emu.winHttpHandles.delete(emu.readArg(0));
    return 1;
  });

winhttp.register('WinHttpConnect', 4, () => {
  const hSession = emu.readArg(0);
  const pswzServerName = emu.readArg(1);

  // ✅ 真正的修复：忽略堆栈高位的脏数据，仅截断取 16 位的实际端口值
  // 这样 0xABCD0050 就会被干净地转换为 0x0050 (80)
  const nServerPort = emu.readArg(2) & 0xFFFF;

  const serverName = pswzServerName ? emu.memory.readUTF16String(pswzServerName) : '';
  
  return hAlloc('connect', { serverName, port: nServerPort });
});

  // 🌟 拦截路径，构建完整的专属 URL
  winhttp.register('WinHttpOpenRequest', 7, () => {
    const hConnect = emu.readArg(0);
    const pwszObjectName = emu.readArg(2);
    const dwFlags = emu.readArg(6); // 判断是否是 HTTPS (WINHTTP_FLAG_SECURE = 0x00800000)
    
    const connectData = emu.winHttpHandles.get(hConnect)?.data;
    const path = pwszObjectName ? emu.memory.readUTF16String(pwszObjectName) : '/';
    
    const protocol = (dwFlags & 0x00800000) ? 'https' : 'http';
    const portStr = (connectData?.port === 80 || connectData?.port === 443) ? '' : `:${connectData?.port}`;
    const fullUrl = `${protocol}://${connectData?.serverName || 'localhost'}${portStr}${path}`;

    return hAlloc('request', {
      url: fullUrl,
      responseText: '',
      responseBody: new Uint8Array(0),
      isBinary: false,
      contentType: '',
      statusCode: 0
    });
  });

// ------------------------------
// 已修复：完美兼容 Delphi URL_COMPONENTS (32位)
// ------------------------------
winhttp.register('WinHttpCrackUrl', 4, () => {
  const pwszUrl = emu.readArg(0);
  const dwUrlLength = emu.readArg(1);
  const dwFlags = emu.readArg(2);
  const pUrlComponents = emu.readArg(3);

  if (!pwszUrl || !pUrlComponents) return 0;

  // 1. 读取 URL
  const urlStr = emu.memory.readUTF16String(pwszUrl);
  let parsed: URL;
  try {
    parsed = new URL(urlStr);
  } catch (e) {
    console.error('[WinHttpCrackUrl] 解析失败:', urlStr);
    return 0;
  }

  // =========================================================================
  // 微软官方 32位 URL_COMPONENTS 结构体偏移（绝对正确）
  // =========================================================================
  const OFFSET = {
    dwStructSize: 0,
    lpszScheme: 4,
    dwSchemeLength: 8,
    nScheme: 12,
    lpszHostName: 16,
    dwHostNameLength: 20,
    nPort: 24,
    lpszUserName: 28,
    dwUserNameLength: 32,
    lpszPassword: 36,
    dwPasswordLength: 40,
    lpszUrlPath: 44,
    dwUrlPathLength: 48,
    lpszExtraInfo: 52,
    dwExtraInfoLength: 56
  };

  // 2. 读取结构体大小（必须校验）
  const structSize = emu.memory.readU32(pUrlComponents + OFFSET.dwStructSize);
  if (structSize !== 60) { // 32位正确大小 = 60字节
    return 0;
  }

  // 3. 协议类型 http=1 / https=2
  const isHttps = parsed.protocol === 'https:';
  const nScheme = isHttps ? 2 : 1;
  emu.memory.writeU32(pUrlComponents + OFFSET.nScheme, nScheme);

  // 4. 端口
  let port = parseInt(parsed.port, 10) || (isHttps ? 443 : 80);
  emu.memory.writeU16(pUrlComponents + OFFSET.nPort, port);

  // 5. 写入 HostName（Delphi 传入的缓冲区）
  const lpszHostName = emu.memory.readU32(pUrlComponents + OFFSET.lpszHostName);
  const hostMaxLen = emu.memory.readU32(pUrlComponents + OFFSET.dwHostNameLength);
  if (lpszHostName && hostMaxLen > 0) {
    const host = parsed.hostname;
    const writeLen = Math.min(host.length, hostMaxLen - 1);
    writeUTF16String(emu, lpszHostName, host.substring(0, writeLen));
    emu.memory.writeU32(pUrlComponents + OFFSET.dwHostNameLength, writeLen);
  }

  // 6. 写入 Path + Query（Delphi 必须）
  const lpszUrlPath = emu.memory.readU32(pUrlComponents + OFFSET.lpszUrlPath);
  const pathMaxLen = emu.memory.readU32(pUrlComponents + OFFSET.dwUrlPathLength);
  if (lpszUrlPath && pathMaxLen > 0) {
    const path = parsed.pathname + parsed.search;
    const writeLen = Math.min(path.length, pathMaxLen - 1);
    writeUTF16String(emu, lpszUrlPath, path.substring(0, writeLen));
    emu.memory.writeU32(pUrlComponents + OFFSET.dwUrlPathLength, writeLen);
  }

  //console.log(`[WinHttpCrackUrl] 成功: ${parsed.hostname}${parsed.pathname}`);
  return 1;
});

  // ------------------------------
  // 发送请求
  // ------------------------------
  winhttp.register('WinHttpSendRequest', 7, () => {
    const req = emu.winHttpHandles.get(emu.readArg(0))?.data;
    if (!req || !req.url) return 0;

  //  console.log(`[WinHTTP] Sending request to: ${req.url}`);
    const res = fetchAutoResponse(req.url);
    if (!res) return 0;

    req.isBinary = res.isBinary;
    req.responseBody = res.body;
    req.contentType = res.contentType;
    req.statusCode = res.statusCode;

   // console.log(`[WinHTTP] Status: ${res.statusCode}, Body size: ${res.body.length} bytes`);
    return 1;
  });

  winhttp.register('WinHttpReceiveResponse', 3, () => 1);

  // ------------------------------
  // 🌟 查询响应头 (修复 UTF-16 和长度溢出问题)
  // ------------------------------
  winhttp.register('WinHttpQueryHeaders', 5, () => {
    const hRequest = emu.readArg(0);
    const dwInfoLevel = emu.readArg(1) & 0xFFFF; // 忽略高位的 FLAG
    const lpBuffer = emu.readArg(3);
    const lpdwBufferLength = emu.readArg(4);

    const req = emu.winHttpHandles.get(hRequest)?.data;
    if (!req || !lpBuffer || !lpdwBufferLength) return 0;

    let resultStr = "";
    if (dwInfoLevel === 1) { // HTTP_QUERY_CONTENT_TYPE
      resultStr = req.contentType || 'application/octet-stream';
    } else if (dwInfoLevel === 19) { // HTTP_QUERY_STATUS_CODE
      resultStr = String(req.statusCode || 200);
    } else {
      return 0; // 其他头暂时不支持
    }

    const requiredBytes = (resultStr.length + 1) * 2; // UTF-16 包含 null 终止符的字节数
    const bufferSize = emu.memory.readU32(lpdwBufferLength);

    // 如果缓冲区不够大，写入所需大小，返回 FALSE (LastError 应该是 ERROR_INSUFFICIENT_BUFFER)
    if (bufferSize < requiredBytes) {
      emu.memory.writeU32(lpdwBufferLength, requiredBytes);
      return 0; 
    }

    // 写入宽字符文本和实际写入的字节数
    writeUTF16String(emu, lpBuffer, resultStr);
    emu.memory.writeU32(lpdwBufferLength, requiredBytes - 2); // 规范要求返回不含 null 的字节数
    return 1;
  });

  winhttp.register('WinHttpQueryDataAvailable', 2, () => {
    const req = emu.winHttpHandles.get(emu.readArg(0))?.data;
    const pLen = emu.readArg(1);
    emu.memory.writeU32(pLen, req?.responseBody?.length || 0);
    return 1;
  });

  // ------------------------------
  // 🌟 统一二进制读取 (带有高速拷贝优化)
  // ------------------------------
  winhttp.register('WinHttpReadData', 4, () => {
    const req = emu.winHttpHandles.get(emu.readArg(0))?.data;
    const dst = emu.readArg(1);
    const maxSize = emu.readArg(2);
    const outRead = emu.readArg(3);

    if (!req || !dst || !outRead) return 0;

    const body = req.responseBody ?? new Uint8Array(0);
    const copyLen = Math.min(maxSize, body.length);

    // 尝试寻找模拟器内存底层的 TypedArray 实现，用于高速整块拷贝（性能飙升）
    if ((emu.memory as any).buffer instanceof ArrayBuffer) {
      const memoryView = new Uint8Array((emu.memory as any).buffer);
      memoryView.set(body.subarray(0, copyLen), dst);
    } else {
      // 如果没有，自动回退到逐字节写入以保证兼容
      for (let i = 0; i < copyLen; i++) {
        emu.memory.writeU8(dst + i, body[i]);
      }
    }

    // 更新请求状态，消耗已读取的数据
    req.responseBody = body.slice(copyLen);

    emu.memory.writeU32(outRead, copyLen);
    return 1;
  });

  // ------------------------------
  // 其他补充 API
  // ------------------------------
  winhttp.register('WinHttpAddRequestHeaders', 4, () => 1);
  winhttp.register('WinHttpSetOption', 4, () => 1);
  winhttp.register('WinHttpQueryOption', 4, () => 0);
  winhttp.register('WinHttpWriteData', 5, () => 1);
  winhttp.register('WinHttpCreateUrl', 1, () => 0);
  winhttp.register('WinHttpSetStatusCallback', 4, () => 0);
  winhttp.register('WinHttpSetTimeouts', 5, () => 1);
  winhttp.register('WinHttpTimeFromSystemTime', 2, () => 1);
  winhttp.register('WinHttpTimeToSystemTime', 2, () => 1);
  winhttp.register('WinHttpGetProxyForUrl', 3, () => 0);
  winhttp.register('WinHttpGetIEProxyConfigForCurrentUser', 1, () => 0);
  winhttp.register('WinHttpDetectAutoProxyConfigUrl', 2, () => 0);
  winhttp.register('WinHttpAutoProxySvcMain', 4, () => 0);
  winhttp.register('WinHttpWebSocketClose', 3, () => 0);
  winhttp.register('WinHttpWebSocketReceive', 4, () => 0);
  winhttp.register('WinHttpWebSocketSend', 3, () => 0);
  winhttp.register('WinHttpWebSocketShutdown', 3, () => 0);
  winhttp.register('WinHttpWebSocketOpen', 6, () => 0);
}


